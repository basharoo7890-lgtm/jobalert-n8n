      "id": "075c0d22-83aa-4cd3-8b9d-f028d886ab11",
      "name": "Transform & Clean Job Data"
    },
    {
      "parameters": {
        "jsCode": "// 1. جلب كافة العناصر من عقدة جوجل شيت لمنع التكرار\nconst inputItems = $items(\"Read Stored Job IDs\");\nconst oldJobIds = inputItems\n    .filter(item => item.json && item.json.Job_ID)\n    .map(item => item.json.Job_ID.toString());\n\n// 2. مصفوفات ذكية (Smart Arrays) للبحث الدلالي\n// أ. المسميات والمفاهيم العامة\nconst concepts = [\"devops\", \"cloud\", \"sre\", \"platform\", \"infrastructure\", \"automation\", \"ci/cd\"];\n// ب. الأدوات والتقنيات (Tools & Tech Stack) - هذا هو المفتاح الجديد\nconst tools = [\"kubernetes\", \"docker\", \"terraform\", \"ansible\", \"jenkins\", \"gitlab ci\", \"aws\", \"azure\", \"gcp\", \"linux\", \"bash\", \"python\"];\n\n// ج. الكلمات المستبعدة (الأقدمية العالية)\nconst seniorKeywords = [\"senior\", \"lead\", \"manager\", \"head\", \"architect\", \"principal\"];\n\n// 3. دالة التصفية الرئيسية\nreturn items.filter(item => {\n    // توحيد النصوص\n    const title = (item.json.Title || \"\").toLowerCase();\n    const description = (item.json.Full_Description || \"\").toLowerCase();\n    const fullText = title + \" \" + description;\n    const jobId = item.json.Job_ID?.toString();\n\n    // أ. البحث عن المفاهيم (Concepts)\n    const hasConcept = concepts.some(keyword => fullText.includes(keyword));\n    \n    // ب. البحث عن الأدوات (Tools) - تقنية استخراج المهارات\n    // نطلب وجود أداة واحدة على الأقل لضمان صلة الوظيفة بـ DevOps\n    let toolsMatched = 0;\n    tools.forEach(tool => {\n        if (fullText.includes(tool)) toolsMatched++;\n    });\n    const hasTools = toolsMatched >= 1; // يكفي وجود أداة واحدة للعبور\n\n    // ج. التحقق من الأقدمية الصريحة بالكلمات (Explicit Seniority)\n    const hasSeniorWord = seniorKeywords.some(keyword => fullText.includes(keyword));\n\n    // د. التحقق من الخبرة بالأرقام (Numerical Experience)\n    const expRegex = /(\\d+)\\s*(year|yr|yrs|سنة|سنوات)/gi;\n    let maxYearsDetected = 0;\n    let match;\n    while ((match = expRegex.exec(fullText)) !== null) {\n        maxYearsDetected = Math.max(maxYearsDetected, parseInt(match[1]));\n    }\n    // نستبعدها فقط إذا كانت الأرقام أعلى من 6 سنوات (أو أي رقم تراه مناسباً كحد أقصى للمستوى المتوسط/المبتدئ)\n    const isTooSeniorByNumber = maxYearsDetected > 6;\n\n    // هـ. التحقق من التكرار\n    const isNewJob = !oldJobIds.includes(jobId);\n\n    // المنطق النهائي للمرور (The Final Gate)\n    // يجب أن تكون الوظيفة غير مكررة + ليست لمدير/خبير (بالكلمات أو الأرقام)\n    // ويجب أن تحتوي إما على مسمى صريح (Concepts) أو أدوات تقنية (Tools)\n    const isRelevant = hasConcept || hasTools;\n    const isAppropriateLevel = !hasSeniorWord && !isTooSeniorByNumber;\n\n    // ملاحظة هامة: إذا لم يتم العثور على أرقام أو كلمات خبرة، ستعتبر الوظيفة مقبولة وتمر للذكاء الاصطناعي\n    return isRelevant && isAppropriateLevel && isNewJob;\n});"
      },
